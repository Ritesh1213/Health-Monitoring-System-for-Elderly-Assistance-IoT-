/* ================= WIFI ================= */

void setupWiFi()
{
  Serial.println("Connecting WiFi...");
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);

  while (WiFi.status() != WL_CONNECTED)
  {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nWiFi Connected ✅");
}

/* ================= TEMPERATURE ================= */

float readTemperature()
{
  int sum = 0;
  for (int i = 0; i < 10; i++)
  {
    sum += analogRead(LM35_PIN);
    delay(5);
  }

  float avg = sum / 10.0;
  float voltage = avg * (3.3 / 4095.0);
  float temp = voltage * 100.0;

  temp = temp - 30.0;

  Serial.print("Temp: ");
  Serial.println(temp);

  return temp;
}

/* ================= MPU ================= */

void setupMPU()
{
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x6B);
  Wire.write(0);
  Wire.endTransmission(true);
}

void readMPU()
{
  int16_t ax_raw, ay_raw, az_raw;

  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x3B);
  Wire.endTransmission(false);
  Wire.requestFrom(MPU_ADDR, 6, true);

  if (Wire.available() == 6)
  {
    ax_raw = Wire.read() << 8 | Wire.read();
    ay_raw = Wire.read() << 8 | Wire.read();
    az_raw = Wire.read() << 8 | Wire.read();

    ax = ax_raw / 16384.0;
    ay = ay_raw / 16384.0;
    az = az_raw / 16384.0;

    float rawMag = sqrt(ax * ax + ay * ay + az * az);
    accelMag = 0.8 * accelMag + 0.2 * rawMag;
  }
}

/* ================= FALL DETECTION (FIX ADDED) ================= */

void detectFall()
{
  if (accelMag < 0.5 && !freeFall)
  {
    freeFall = true;
    freeFallTime = millis();
  }

  if (freeFall && accelMag > 3.0)
  {
    impact = true;
    impactTime = millis();
  }

  if (impact && millis() - impactTime > 1500)
  {
    fallDetected = true;
    Serial.println("⚠ FALL DETECTED ⚠");

    freeFall = false;
    impact = false;
  }

  if (freeFall && millis() - freeFallTime > 2000)
  {
    freeFall = false;
    impact = false;
  }
}

/* ================= MAX30102 ================= */

void setupMAX()
{
  if (!particleSensor.begin(Wire, I2C_SPEED_FAST))
  {
    Serial.println("MAX30102 NOT FOUND ❌");
    while (1);
  }

  particleSensor.setup();
  particleSensor.setPulseAmplitudeRed(0x1F);
  particleSensor.setPulseAmplitudeIR(0x1F);
}

void readMAX()
{
  for (byte i = 0; i < BUFFER_SIZE; i++)
  {
    while (!particleSensor.available())
      particleSensor.check();

    redBuffer[i] = particleSensor.getRed();
    irBuffer[i] = particleSensor.getIR();
    particleSensor.nextSample();
  }

  int irValue = irBuffer[BUFFER_SIZE - 1];

  Serial.print("IR: ");
  Serial.println(irValue);

  if (irValue < 20000)
  {
    Serial.println("No finger ❌");
    heartRate = 0;
    spo2 = 0;
    validHeartRate = 0;
    validSPO2 = 0;
    return;
  }

  maxim_heart_rate_and_oxygen_saturation(
    irBuffer,
    BUFFER_SIZE,
    redBuffer,
    &spo2,
    &validSPO2,
    &heartRate,
    &validHeartRate
  );
}

/* ================= OLED ================= */

void setupOLED()
{
  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);
}

void updateDisplay(float temp)
{
  display.clearDisplay();

  display.setCursor(0, 0);
  display.print("Temp: "); display.println(temp);
  display.print("HR: "); display.println(heartRate);
  display.print("SpO2: "); display.println(spo2);
  display.print("Fall: "); display.println(fallDetected ? "YES" : "NO");

  display.display();
}

/* ================= SEND ================= */

void sendData(float temp)
{
  if (WiFi.status() != WL_CONNECTED) return;

  HTTPClient http;
  http.begin(SERVER_URL);
  http.addHeader("Content-Type", "application/json");

  StaticJsonDocument<256> doc;

  // ❌ ignore invalid readings
  if (heartRate <= 0 || spo2 <= 0)
  {
    Serial.println("Invalid sensor data, skipping...");
    return;
  }

  // ✅ correct format
  doc["heart_rate"] = heartRate;
  doc["spo2"] = spo2;

  // ✅ clamp temperature
  if (temp > 50) temp = 36;
  doc["temperature"] = temp;

  String json;
  serializeJson(doc, json);

  Serial.print("Sending: ");
  Serial.println(json);

  int code = http.POST(json);

  Serial.print("HTTP Response: ");
  Serial.println(code);

  http.end();
}
/* ================= SETUP ================= */

void setup()
{
  Serial.begin(115200);
  delay(1000);

  Wire.begin(8, 9);  // ESP32-C3 I2C pins

  pinMode(LM35_PIN, INPUT);

  setupOLED();
  setupWiFi();
  setupMPU();
  setupMAX();

  Serial.println("System Ready ✅");
}
/* ================= LOOP ================= */

void loop()
{
  float temp = readTemperature();

  readMPU();
  readMAX();
  detectFall();

  updateDisplay(temp);
  sendData(temp);

  delay(2000);
}
